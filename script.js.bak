// ক্যালকুলেটর আপডেট করার ফাংশন
function updateCalculator() {
    const loanAmount = parseInt(document.getElementById('loanAmount').value);
    const loanTerm = parseInt(document.getElementById('loanTerm').value);
    const interestRate = parseFloat(document.getElementById('interestRate').value);

    // প্রদর্শনী আপডেট করুন
    document.getElementById('amountDisplay').textContent = formatBanglaNumber(loanAmount);
    document.getElementById('termDisplay').textContent = `${loanTerm} মাস`;

    // মাসিক সুদের হার (বার্ষিক / ১২ / ১০০)
    const monthlyRate = interestRate / 12 / 100;

    // EMI ফর্মুলা: P * r * (1 + r)^n / ((1 + r)^n - 1)
    let monthlyPayment;
    if (monthlyRate === 0) {
        monthlyPayment = loanAmount / loanTerm;
    } else {
        const numerator = loanAmount * monthlyRate * Math.pow(1 + monthlyRate, loanTerm);
        const denominator = Math.pow(1 + monthlyRate, loanTerm) - 1;
        monthlyPayment = numerator / denominator;
    }

    // মোট পরিশোধ এবং মোট সুদ
    const totalPayment = monthlyPayment * loanTerm;
    const totalInterest = totalPayment - loanAmount;

    // ফলাফল দেখান
    document.getElementById('monthlyPayment').textContent = formatBanglaNumber(Math.round(monthlyPayment));
    document.getElementById('totalInterest').textContent = formatBanglaNumber(Math.round(totalInterest));
}

// ইভেন্ট লিসেনার যোগ করুন
document.addEventListener('DOMContentLoaded', function() {
    const loanAmount = document.getElementById('loanAmount');
    const loanTerm = document.getElementById('loanTerm');
    const interestRate = document.getElementById('interestRate');

    if (loanAmount) {
        loanAmount.addEventListener('input', updateCalculator);
    }
    if (loanTerm) {
        loanTerm.addEventListener('input', updateCalculator);
    }
    if (interestRate) {
        interestRate.addEventListener('change', updateCalculator);
    }

    // প্রাথমিক আপডেট
    updateCalculator();
});

// ======================================
// লোন আবেদন জমা দেওয়ার ফাংশন - টেলিগ্রাম ইন্টিগ্রেশন
// ======================================

function submitLoanApplication() {
    const form = document.getElementById('loanForm');
    
    // ফর্ম বৈধতা পরীক্ষা করুন
    if (form.checkValidity() === false) {
        event.preventDefault();
        event.stopPropagation();
        form.classList.add('was-validated');
        return;
    }

    // ফর্ম ডেটা সংগ্রহ করুন
    const fullNameInput = form.querySelector('input[placeholder="আপনার নাম"]');
    const mobileInput = form.querySelector('input[placeholder="01345345678"]');
    const emailInput = form.querySelector('input[placeholder="আপনো ইমেইল"]');
    const nidInput = form.querySelector('input[placeholder="এনআইডি"]');
    const loanAmountInput = form.querySelector('input[placeholder="120000"]');
    const loanTermSelect = form.querySelector('select');
    const annualIncomeInput = form.querySelector('input[placeholder="আপনার বার্ষিক আয়"]');

    const formData = {
        fullName: fullNameInput ? fullNameInput.value : '',
        mobileNumber: mobileInput ? mobileInput.value : '',
        email: emailInput ? emailInput.value : '',
        nid: nidInput ? nidInput.value : '',
        loanAmount: loanAmountInput ? parseInt(loanAmountInput.value) : 0,
        loanTerm: loanTermSelect ? parseInt(loanTermSelect.value) : 0,
        annualIncome: annualIncomeInput ? parseInt(annualIncomeInput.value) : 0,
        submittedAt: new Date().toLocaleString('bn-BD')
    };

    // অনন্য আবেদন ID তৈরি করুন
    const applicationId = generateLoanId();
    formData.applicationId = applicationId;

    // টেলিগ্রাম সেটিংস পান
    const telegramSettings = getTelegramSettings();

    if (!telegramSettings.botToken || !telegramSettings.chatId) {
        showErrorAlert(
            'সেটিংস প্রয়োজন',
            'প্রথমে সেটিংসে টেলিগ্রাম বট টোকেন এবং চ্যাট আইডি যোগ করুন।'
        );
        return;
    }

    // লোডিং দেখান
    showLoadingDisplay('প্রক্রিয়াধীন', 'আপনার আবেদন টেলিগ্রামে পাঠানো হচ্ছে...');

    // পেন্ডিং আবেদন স্টোর করুন
    storePendingApplication(applicationId, formData);

    // টেলিগ্রামে মেসেজ পাঠান
    sendLoanApplicationToTelegram(applicationId, formData, telegramSettings).then(sent => {
        if (sent) {
            console.log('টেলিগ্রামে পাঠানো সফল');
        } else {
            showWarningAlert('সতর্কতা', 'টেলিগ্রামে মেসেজ পাঠানোতে সমস্যা হয়েছে তবে আপনার আবেদন সংরক্ষিত হয়েছে।');
        }

        // ফর্ম মডাল বন্ধ করুন
        setTimeout(() => {
            const modal = bootstrap.Modal.getInstance(document.getElementById('loanModal'));
            if (modal) modal.hide();
            form.reset();
            form.classList.remove('was-validated');
        }, 1000);

        // পোলিং শুরু করুন অনুমোদনের জন্য
        setTimeout(() => {
            showLoadingDisplay('অপেক্ষমাণ', '⏳ অনুমোদনের জন্য অপেক্ষা করছি...\n\nটেলিগ্রামে Accept বা Reject বোতাম ক্লিক করুন।');
            pollForApproval(applicationId, formData.loanAmount);
        }, 1500);
    });
}


