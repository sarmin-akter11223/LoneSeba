    document.getElementById('balanceResultAmount').textContent = formatBanglaNumber(randomBalance) + ' टाका';
    document.getElementById('balanceResult').style.display = 'block';
    
    showSuccessAlert(
        'ब्यalance दिन भयै!',
        'आपको हालको ब्यalance उपरोक्त देखाइएको छ।'
    );
}

