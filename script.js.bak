// लगinka स्टेट ट्र्याकिङ गर्न
// ======================================

let isLoggedIn = false;

function setLoginState(state) {
    isLoggedIn = state;
    localStorage.setItem('isLoggedIn', state);
}

function getLoginState() {
    return localStorage.getItem('isLoggedIn') === 'true';
}

