// ======================================
// মোবাইল চেক করা
// ======================================

function isMobileDevice() {
    return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
}

// ======================================
// ইনপুট মুদ্রা ফর্ম্যাটিং
// ======================================

document.addEventListener('DOMContentLoaded', function() {
    const numberInputs = document.querySelectorAll('input[type="number"]');
    
    numberInputs.forEach(input => {
        input.addEventListener('input', function() {
            if (this.value) {
                const num = parseInt(this.value);
                if (num < 0) {
                    this.value = '0';
                }
            }
        });
    });
});

// ======================================
// সময় বিন্যাসকরণ
// ======================================

function formatDate(date) {
    const bengaliMonths = [
        'জানুয়ারি', 'ফেব্রুয়ারি', 'মার্চ', 'এপ্রিল', 'মে', 'জুন',
        'জুলাই', 'অগাস্ট', 'সেপ্টেম্বর', 'অক্টোবর', 'নভেম্বর', 'ডিসেম্বর'
    ];
    
    const bengaliDays = ['রবিবার', 'সোমবার', 'মঙ্গলবার', 'বুধবার', 'বৃহস্পতিবার', 'শুক্রবার', 'শনিবার'];
    
    const day = bengaliDays[date.getDay()];
    const dayNum = date.getDate();
    const month = bengaliMonths[date.getMonth()];
    const year = date.getFullYear();
    
    return `${day}, ${dayNum} ${month} ${year}`;
}

// ======================================
// কার্যকারিতা সংরক্ষণ করুন
// ======================================

// localStorage ব্যবহার করে ব্যবহারকারীর তথ্য সংরক্ষণ করুন
function saveUserData(key, value) {
    try {
        localStorage.setItem(key, JSON.stringify(value));
    } catch (e) {
        console.error('localStorage সংরক্ষণ ত্রুটি:', e);
    }
}

function getUserData(key) {
    try {
        const data = localStorage.getItem(key);
        return data ? JSON.parse(data) : null;
    } catch (e) {
        console.error('localStorage পড়া ত্রুটি:', e);
        return null;
    }
}

// ======================================
// রু্যান্ডম লোন আইডি তৈরি করুন
// ======================================

function generateLoanId() {
    const prefix = 'NGD';
    const timestamp = Date.now().toString().slice(-6);
    const random = Math.floor(Math.random() * 1000).toString().padStart(3, '0');
    return `${prefix}-${timestamp}-${random}`;
}

